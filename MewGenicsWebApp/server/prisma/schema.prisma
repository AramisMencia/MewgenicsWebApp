generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cat {
  id        Int      @id @default(autoincrement())
  name      String
  gender    Gender
  orientation Orientation
  inbreeding_level Int
  color     String
  status    Status
  created_at DateTime @default(now())

  stats     CatStats?
  abilities CatAbility[]

  // 🧬 PADRES
  motherId Int?
  fatherId Int?

  mother   Cat? @relation("Mother", fields: [motherId], references: [id])
  father   Cat? @relation("Father", fields: [fatherId], references: [id])

  // 🧬 HIJOS
  childrenAsMother Cat[] @relation("Mother")
  childrenAsFather Cat[] @relation("Father")
}

model CatStats {
  id           Int  @id @default(autoincrement())
  cat          Cat  @relation(fields: [cat_id], references: [id])
  cat_id       Int  @unique

  strength      Int
  dexterity     Int
  constitution  Int
  intelligence   Int
  agility       Int
  charisma      Int
  luck          Int
}

model Ability {
  id    Int    @id @default(autoincrement())
  name  String @unique

  cats  CatAbility[]
}

model CatAbility {
  cat        Cat     @relation(fields: [cat_id], references: [id])
  cat_id     Int

  ability    Ability @relation(fields: [ability_id], references: [id])
  ability_id Int

  @@id([cat_id, ability_id])
}

enum Gender {
  male
  female
  unknown
}

enum Orientation {
  hetero
  homo
  bi
}

enum Status {
  alive
  retired
  dead
}



